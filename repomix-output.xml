      </div>

      {user ? (
        <button
          onClick={logout}
          className="rounded-xl bg-gray-200 px-4 py-2 font-semibold text-gray-700"
        >
          ログアウト
        </button>
      ) : (
        <button
          onClick={signInWithGoogle}
          className="rounded-xl bg-orange-500 px-4 py-2 font-semibold text-white"
        >
          Googleでログイン
        </button>
      )}
